{
  "name": "@cstrlcs/sva",
  "version": "1.3.0",
  "description": "Style Variant Authority for React Native",
  "keywords": [
    "react-native",
    "style",
    "styling",
    "theme",
    "variants"
  ],
  "license": "MIT",
  "author": "Lucas Castro (https://github.com/cstrlcs/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cstrlcs/sva.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:js": "bun build src/index.ts --outdir dist --target bun --external typescript --external react-native --minify",
    "build:dts": "tsc -p tsconfig.build.json",
    "build": "bun run build:js && bun run build:dts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix && oxfmt",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@cstrlcs/configs": "^7.3.0",
    "@types/bun": "latest",
    "@types/react-native": "latest",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "react-native": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "react-native": "*"
  }
}
